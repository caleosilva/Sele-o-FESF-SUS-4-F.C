# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sus_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=sus_db

# ── Backend / API ─────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# Gere uma chave segura com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_para_chave_segura_aleatoria

ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL que o NAVEGADOR usa para acessar a API (porta exposta no host).
# Não altere se estiver rodando localmente com as portas padrão.
NEXT_PUBLIC_API_URL=http://localhost:8000
